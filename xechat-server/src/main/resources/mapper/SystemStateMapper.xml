<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.xeblog.server.account.mapper.SystemStateMapper">

    <select id="get" resultType="string">
        SELECT value FROM system_state WHERE key = #{key}
    </select>

    <!-- SQLite 的 UPSERT: ON CONFLICT(key) DO UPDATE -->
    <insert id="set">
        INSERT INTO system_state (key, value) VALUES (#{key}, #{value})
        ON CONFLICT(key) DO UPDATE SET value = excluded.value
    </insert>

    <delete id="delete">
        DELETE FROM system_state WHERE key = #{key}
    </delete>

</mapper>
